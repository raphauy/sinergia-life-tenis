generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  SUPERADMIN
  ADMIN
  PLAYER
}

enum MatchStatus {
  PENDING
  CONFIRMED
  PLAYED
  CANCELLED
}

enum MatchFormat {
  SINGLE_SET
  TWO_SETS_SUPERTB
  BEST_OF_THREE
}

enum MatchStage {
  GROUP
  QUARTERFINAL
  SEMIFINAL
  FINAL
}

enum ImportedPlayerStatus {
  PENDING
  PROCESSED
  ERROR
}

enum ChallengeStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum RatingChangeReason {
  SEED
  MATCH
  PENALTY
  ADJUSTMENT
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  image     String?
  phone     String?
  cedula    String?
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otpTokens            OtpToken[]
  players              Player[]
  matchesAsPlayer1     Match[]       @relation("MatchPlayer1")
  matchesAsPlayer2     Match[]       @relation("MatchPlayer2")
  matchesWon           MatchResult[] @relation("MatchWinner")
  matchResultsReported MatchResult[] @relation("MatchReporter")
  invitationsSent      AdminInvitation[] @relation("InvitationSender")
  slotReservations     SlotReservation[]
  ladderMemberships       LadderMember[]
  challengesAsChallenger  Challenge[]   @relation("ChallengeChallenger")
  challengesAsChallenged  Challenge[]   @relation("ChallengeChallenged")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model OtpToken {
  id        String    @id @default(cuid())
  token     String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AdminInvitation {
  id          String    @id @default(cuid())
  email       String
  firstName   String?
  lastName    String?
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  createdAt   DateTime  @default(now())

  invitedBy User @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model Tournament {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  rules       String?
  matchFormat MatchFormat  @default(SINGLE_SET)
  startDate   DateTime
  endDate     DateTime
  finalsDate  DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  categories TournamentCategory[]
  matches    Match[]
  players    Player[]

  @@index([isActive])
  @@index([slug])
}

model TournamentCategory {
  id           String   @id @default(cuid())
  tournamentId String
  name         String
  description  String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players    Player[]
  matches    Match[]
  groups     Group[]

  @@unique([tournamentId, name])
  @@index([tournamentId])
}

model Group {
  id         String   @id @default(cuid())
  categoryId String
  number     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  players  Player[]
  matches  Match[]
  bracketPlayer1Sources Match[] @relation("MatchPlayer1SourceGroup")
  bracketPlayer2Sources Match[] @relation("MatchPlayer2SourceGroup")

  @@unique([categoryId, number])
  @@index([categoryId])
}

model Player {
  id              String    @id @default(cuid())
  slug            String    @unique
  userId          String?
  tournamentId    String
  categoryId      String
  groupId         String?
  firstName       String
  lastName        String
  whatsappNumber  String?
  email           String?
  invitationToken String?   @unique
  invitedAt       DateTime?
  acceptedAt      DateTime?
  withdrawnAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  tournament Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category   TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group      Group?             @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, email])
  @@index([tournamentId])
  @@index([withdrawnAt])
  @@index([categoryId])
  @@index([userId])
  @@index([groupId])
  @@index([invitationToken])
  @@index([slug])
}

// Polimórfico (ADR 0001): un partido es de torneo (tournamentId+categoryId) XOR de
// escalera (ladderId). La invariante se impone con un CHECK en BD ("match_tournament_xor_ladder",
// ver la migración) que el schema no refleja — Prisma no introspecta CHECKs, así que
// un `db push` o regeneración desde el schema NO lo recrearía.
model Match {
  id           String      @id @default(cuid())
  tournamentId String?
  categoryId   String?
  ladderId     String?
  groupId      String?
  stage        MatchStage  @default(GROUP)
  bracketPosition Int?
  player1Id    String?
  player2Id    String?
  player1SourceGroupId  String?
  player1SourcePosition Int?
  player2SourceGroupId  String?
  player2SourcePosition Int?
  courtNumber  Int?
  scheduledAt  DateTime?
  status       MatchStatus @default(PENDING)
  confirmedAt  DateTime?
  playedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tournament Tournament?        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category   TournamentCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  ladder     Ladder?            @relation(fields: [ladderId], references: [id], onDelete: Cascade)
  challenge  Challenge?
  group      Group?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  player1    User?              @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2    User?              @relation("MatchPlayer2", fields: [player2Id], references: [id])
  player1SourceGroup Group?     @relation("MatchPlayer1SourceGroup", fields: [player1SourceGroupId], references: [id], onDelete: SetNull)
  player2SourceGroup Group?     @relation("MatchPlayer2SourceGroup", fields: [player2SourceGroupId], references: [id], onDelete: SetNull)
  result      MatchResult?
  reservation SlotReservation?
  ratingHistory RatingHistory[]

  @@index([tournamentId])
  @@index([categoryId])
  @@index([ladderId])
  @@index([groupId])
  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
  @@index([stage])
  @@index([categoryId, stage])
  @@index([player1SourceGroupId])
  @@index([player2SourceGroupId])
  @@index([scheduledAt])
}

model MatchResult {
  id             String   @id @default(cuid())
  matchId        String   @unique
  reportedById   String
  set1Player1    Int
  set1Player2    Int
  tb1Player1     Int?
  tb1Player2     Int?
  set2Player1    Int?
  set2Player2    Int?
  tb2Player1     Int?
  tb2Player2     Int?
  superTbPlayer1 Int?
  superTbPlayer2 Int?
  set3Player1    Int?
  set3Player2    Int?
  walkover       Boolean  @default(false)
  winnerId       String
  photoUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reportedBy User  @relation("MatchReporter", fields: [reportedById], references: [id])
  winner     User  @relation("MatchWinner", fields: [winnerId], references: [id])

  @@index([matchId])
  @@index([winnerId])
}

model ImportedPlayer {
  id             String               @id @default(cuid())
  firstName      String
  lastName       String
  category       String
  whatsappNumber String?
  email          String?
  data           Json
  status         ImportedPlayerStatus @default(PENDING)
  error          String?
  tournamentId   String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([tournamentId])
  @@index([status])
  @@index([tournamentId, status])
}

model SlotReservation {
  id          String   @id @default(cuid())
  matchId     String   @unique
  scheduledAt DateTime
  courtNumber Int      @default(2)
  reservedBy  String
  createdAt   DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [reservedBy], references: [id])

  @@index([scheduledAt])
  @@index([reservedBy])
}

// ============================================================================
// LA ESCALERA (liga permanente)
// ============================================================================

model Ladder {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  isActive              Boolean  @default(true)
  // config calibrable
  kFactor               Int      @default(24)
  seedBaseRating        Int      @default(1500) // rating del puesto 1 en el seed
  seedStep              Int      @default(20)   // -20 por puesto
  minMatchesPerMonth    Int      @default(2)
  monthlyPenalty        Int      @default(50)   // -50 por no llegar al mínimo
  maxChallengesPerMonth Int      @default(4)    // retos iniciados por mes
  maxOpenChallenges     Int      @default(2)    // retos abiertos en simultáneo
  acceptanceWindowDays  Int      @default(4)
  reservationLeadDays   Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  members    LadderMember[]
  challenges Challenge[]
  matches    Match[]
  closes     LadderPeriodClose[]

  @@index([slug])
  @@index([isActive])
}

model LadderMember {
  id               String   @id @default(cuid())
  ladderId         String
  userId           String
  rating           Int
  isActive         Boolean  @default(true)
  priorityEligible Boolean  @default(true) // recalculado por el cron (fase 3)
  joinedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ladder        Ladder          @relation(fields: [ladderId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratingHistory RatingHistory[]

  @@unique([ladderId, userId])
  @@index([ladderId])
  @@index([userId])
  @@index([rating])
}

model Challenge {
  id           String          @id @default(cuid())
  ladderId     String
  challengerId String // User
  challengedId String // User
  status       ChallengeStatus @default(PROPOSED)
  proposedAt   DateTime        @default(now())
  respondByAt  DateTime
  respondedAt  DateTime?
  matchId      String?         @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  ladder     Ladder @relation(fields: [ladderId], references: [id], onDelete: Cascade)
  challenger User   @relation("ChallengeChallenger", fields: [challengerId], references: [id])
  challenged User   @relation("ChallengeChallenged", fields: [challengedId], references: [id])
  match      Match? @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([ladderId])
  @@index([challengerId])
  @@index([challengedId])
  @@index([status])
}

model RatingHistory {
  id             String             @id @default(cuid())
  ladderMemberId String
  reason         RatingChangeReason
  matchId        String?
  ratingBefore   Int
  ratingAfter    Int
  delta          Int
  createdAt      DateTime           @default(now())

  member LadderMember @relation(fields: [ladderMemberId], references: [id], onDelete: Cascade)
  match  Match?       @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([ladderMemberId])
  @@index([matchId])
  @@index([createdAt])
}

model LadderPeriodClose {
  id       String   @id @default(cuid())
  ladderId String
  year     Int
  month    Int
  closedAt DateTime @default(now())

  ladder Ladder @relation(fields: [ladderId], references: [id], onDelete: Cascade)

  @@unique([ladderId, year, month])
}
